function trackView8614() {
  let WIDGET_DISPLAYED = false;
  let WIDGET_IN_VIEWPORT = false;

  function trackWidgetInViewport() {
    if (!WIDGET_IN_VIEWPORT) {
      fmdTrackEvent8614('view_widget');
      WIDGET_IN_VIEWPORT = true;
      debugLog('WIDGET_IN_VIEWPORT_TRACKED');
    }
  }

  function isInViewport(element) {
    const rect = element.getBoundingClientRect();
    return ((rect.top > 0 && rect.top < innerHeight) ||
            (rect.bottom > 0 && rect.bottom < innerHeight)) &&
        ((rect.left > 0 && rect.left < innerWidth) || (rect.right > 0 && rect.right < innerWidth));
  }

  function findElement() {
    const element = document.querySelector('.iframe-frontrow-homepage');
    if (element) return element;

    return document.querySelector('#iframe-frontrow-brand');
  }

  function checkVisibility() {
    const element = findElement();
    if (element && isInViewport(element)) {
      trackWidgetInViewport();
      window.removeEventListener('scroll', checkVisibility);
      window.removeEventListener('resize', checkVisibility);
    }
  }

  window.addEventListener('scroll', checkVisibility);
  window.addEventListener('resize', checkVisibility);
  checkVisibility();
}

